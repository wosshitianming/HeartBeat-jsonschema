<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<!--
  MyBatis Generator 配置文件（互联网大厂风格）

  使用方式：
  1. 修改 jdbc.url / jdbc.username / jdbc.password 指向目标数据库
  2. 修改 tableName / domainObjectName 指向需要生成的表
  3. 运行：mvn mybatis-generator:generate
       或 mvn -pl heartbeat-infrastructure mybatis-generator:generate

  生成产物：
  - DO：           top.kx.heartbeat.infrastructure.persistence.entity.gen.*DO
  - Example：      同上包下 *Example（Criteria 内嵌）
  - Mapper 接口：  top.kx.heartbeat.infrastructure.persistence.mapper.gen.*DOMapper
  - XML：          heartbeat-infrastructure/src/main/resources/mapper-xml/gen/*Mapper.xml

  生成物走 .gen 子包，与手写代码物理隔离，避免相互覆盖。

  注意事项：
  - 在 navicat/mysql 命令行确认库 heartbeat 已存在且包含相应表
  - generatorConfig.xml 默认 UTF-8，中文注释无乱码
  - 重新生成前先清空 mapper-xml/gen/ 与 entity/gen、mapper/gen/ 目录（谨慎）
-->
<generatorConfiguration>

    <context id="Mysql" targetRuntime="MyBatis3" defaultModelType="flat">

        <!-- 全表 Example/Criteria 启用（plugin 必须在 commentGenerator 之前） -->
        <plugin type="org.mybatis.generator.plugins.SerializablePlugin"/>
        <plugin type="org.mybatis.generator.plugins.ToStringPlugin"/>
        <plugin type="org.mybatis.generator.plugins.EqualsHashCodePlugin"/>
        <plugin type="org.mybatis.generator.plugins.CaseInsensitiveLikePlugin"/>
        <plugin type="org.mybatis.generator.plugins.RowBoundsPlugin"/>

        <!-- 注释生成策略：保留 Javadoc 注释，便于阅读 -->
        <commentGenerator>
            <property name="suppressAllComments" value="false"/>
            <property name="suppressDate" value="true"/>
            <property name="addRemarkComments" value="true"/>
        </commentGenerator>

        <!-- 数据库连接（dev profile：192.168.204.12:31103 / test_v1） -->
        <jdbcConnection
                driverClass="com.mysql.cj.jdbc.Driver"
                connectionURL="jdbc:mysql://192.168.204.12:31103/test_v1?useUnicode=true&amp;characterEncoding=UTF-8&amp;serverTimezone=Asia/Shanghai&amp;useSSL=false&amp;allowPublicKeyRetrieval=true"
                userId="root"
                password="Ds2Uj4g5hiU6nd0">
            <!-- MySQL 8.x 需要加此属性 -->
            <property name="nullCatalogMeansCurrent" value="true"/>
        </jdbcConnection>

        <!-- 非渐增模式（推荐使用 UUID 或数据库自增） -->
        <javaTypeResolver>
            <property name="forceBigDecimals" value="false"/>
            <property name="useJSR310Types" value="true"/>
        </javaTypeResolver>

        <!-- DO 实体类生成策略：.gen 子包隔离（cwd = heartbeat-infrastructure） -->
        <javaModelGenerator targetPackage="top.kx.heartbeat.infrastructure.persistence.entity.gen"
                           targetProject="src/main/java">
            <property name="useActualParamNames" value="true"/>
            <property name="constructorBased" value="false"/>
            <property name="enableSubPackages" value="false"/>
            <property name="trimStrings" value="true"/>
        </javaModelGenerator>

        <!-- Mapper XML 生成策略 -->
        <sqlMapGenerator targetPackage="mapper-xml/gen"
                         targetProject="src/main/resources">
            <property name="enableSubPackages" value="false"/>
        </sqlMapGenerator>

        <!-- Mapper 接口生成策略：.gen 子包，避免覆盖自写自定义 BaseMapper；XMLMAPPER 才会生成 xml -->
        <javaClientGenerator type="XMLMAPPER"
                             targetPackage="top.kx.heartbeat.infrastructure.persistence.mapper.gen"
                             targetProject="src/main/java">
            <property name="enableSubPackages" value="false"/>
            <property name="exampleMethodVisibility" value="public"/>
            <property name="methodNameCalculator" value="default"/>
        </javaClientGenerator>

